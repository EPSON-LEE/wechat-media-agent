{
  "name": "wechat-media-agent",
  "version": "0.1",
  "description": "Bridge WeChat direct messages and media to any ACP-compatible AI agent",
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "bin": {
    "wechat-media-agent": "./dist/bin/wechat-media-agent.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "prestart": "npm run build",
    "start": "node dist/bin/wechat-media-agent.js --agent codex --cwd . --admin",
    "preadmin": "npm run build",
    "admin": "node dist/bin/wechat-media-agent.js admin",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EPSON-LEE/wechat-media-agent.git"
  },
  "homepage": "https://github.com/EPSON-LEE/wechat-media-agent#readme",
  "bugs": {
    "url": "https://github.com/EPSON-LEE/wechat-media-agent/issues"
  },
  "license": "MIT",
  "keywords": [
    "wechat",
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "bridge"
  ]
}
